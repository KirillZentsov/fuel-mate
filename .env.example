# ─── Telegram ──────────────────────────────────────────────
# From @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Private channel for admin notifications.
# Create channel, add bot as admin, get chat_id (negative number).
ADMIN_CHAT_ID=

# ─── Database (Supabase) ──────────────────────────────────
# From Supabase → Project Settings → Database → Connection string (URI)
# Pooler hostname (aws-N-...) is preferred — it's IPv4 and works from
# both Railway and GitHub Actions runners.
DATABASE_URL=

# ─── Fuel Finder API (gov.uk) ─────────────────────────────
# OAuth 2.0 client credentials. Register at:
#   https://www.developer.fuel-finder.service.gov.uk/
# REQUIRED for production ETL runs. Not needed locally if you only run
# the pipeline with --local-csv.
FUEL_FINDER_CLIENT_ID=
FUEL_FINDER_CLIENT_SECRET=

# Optional override (e.g. to point at staging during development):
# FUEL_FINDER_BASE_URL=https://stg.fuel-finder.ics.gov.uk

# ─── Legacy CSV URL (not used in production) ──────────────
# Kept for documentation. The /internal/.../get-latest-fuel-prices-csv
# endpoint returns 403 to non-residential IPs since early 2026.
# FUEL_PRICES_CSV_URL=https://www.fuel-finder.service.gov.uk/internal/v1.0.2/csv/get-latest-fuel-prices-csv

# ─── GitHub (for raw CSV archive — local CSV runs only) ──
# Personal access token with `repo` scope.
# Not needed locally — GitHub Actions injects this automatically.
GITHUB_TOKEN=
GITHUB_REPO=

# ─── Optional / development ───────────────────────────────
# LOG_LEVEL=DEBUG          # default INFO
# ETL_DRY_RUN=false        # if true, ETL fetches and parses but doesn't write
# POSTCODES_PATH=data/postcodes.csv.gz   # path to the UK postcode index for the bot
